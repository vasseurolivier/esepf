{
  "entities": {
    "AppSettings": {
      "title": "Paramètres de l'Application",
      "description": "Stocke les configurations globales du site comme le logo.",
      "type": "object",
      "properties": {
        "logoUrl": {
          "type": "string",
          "description": "URL de l'image du logo de l'école."
        },
        "schoolName": {
          "type": "string",
          "description": "Nom officiel de l'établissement."
        }
      },
      "required": ["schoolName"]
    },
    "UserProfile": {
      "title": "Profil Utilisateur",
      "description": "Données de profil incluant le rôle administratif.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["admin", "editor", "user"],
          "description": "Le niveau d'accès de l'utilisateur."
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "Information": {
      "title": "Information Publique",
      "description": "Annonces ou informations générales affichées sur le site.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "Article": {
      "title": "Article de Blog",
      "description": "Actualités et articles publiés par l'établissement.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Document unique contenant les réglages globaux du site."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Données des utilisateurs pour la gestion des rôles."
    },
    "/informations/{infoId}": {
      "schema": "Information",
      "description": "Collection d'informations publiques."
    },
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Collection d'articles de blog."
    },
    "/config/{configId}": {
      "schema": { "type": "object", "properties": {} },
      "description": "Données de configuration diverses."
    }
  }
}