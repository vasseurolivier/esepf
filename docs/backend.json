
{
  "entities": {
    "Figure": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Figure",
      "type": "object",
      "description": "Represents a key statistic, achievement, or important number.",
      "properties": {
        "id": { "type": "string" },
        "icon": { "type": "string" },
        "value": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "icon", "value", "description"]
    },
    "Program": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Program",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "shortDescription": { "type": "string" },
        "detailPageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "title", "imageUrl", "shortDescription", "detailPageUrl"]
    },
    "Settings": {
      "title": "Settings",
      "type": "object",
      "description": "Global website configuration.",
      "properties": {
        "schoolName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "images": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Registration": {
      "title": "Registration",
      "type": "object",
      "description": "Student pre-registration application.",
      "properties": {
        "studentFirstName": { "type": "string" },
        "studentLastName": { "type": "string" },
        "studentGender": { "type": "string", "enum": ["boy", "girl"] },
        "studentBirthDate": { "type": "string" },
        "studentNationality": { "type": "string" },
        "languagesSpoken": { "type": "array", "items": { "type": "string" } },
        "studentAddress": { "type": "string" },
        "studentPlaceOfBirth": { "type": "string" },
        "enrollmentDateGoal": { "type": "string" },
        "parent1": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "nationality": { "type": "string" },
            "phone": { "type": "string" },
            "wechat": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "parent2": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "nationality": { "type": "string" },
            "phone": { "type": "string" },
            "wechat": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "selectedPrograms": { "type": "array", "items": { "type": "string" } },
        "campusChoice": { "type": "string" },
        "codeRef": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "contacted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "type": "object",
      "description": "A message sent from the contact form.",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "codeRef": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/figures",
        "definition": {
          "entityName": "Figure",
          "schema": { "$ref": "#/backend/entities/Figure" },
          "description": "Key statistics."
        }
      },
      {
        "path": "/programs",
        "definition": {
          "entityName": "Program",
          "schema": { "$ref": "#/backend/entities/Program" },
          "description": "Academic programs."
        }
      },
      {
        "path": "/settings",
        "definition": {
          "entityName": "Settings",
          "schema": { "$ref": "#/backend/entities/Settings" },
          "description": "Global site settings."
        }
      },
      {
        "path": "/registrations",
        "definition": {
          "entityName": "Registration",
          "schema": { "$ref": "#/backend/entities/Registration" },
          "description": "Student applications."
        }
      },
      {
        "path": "/messages",
        "definition": {
          "entityName": "ContactMessage",
          "schema": { "$ref": "#/backend/entities/ContactMessage" },
          "description": "Messages from contact form."
        }
      },
      {
        "path": "/admins/{userId}",
        "definition": {
          "entityName": "admin",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Administrative users."
        }
      }
    ]
  }
}
