
{
  "entities": {
    "AppSettings": {
      "title": "Paramètres de l'Application",
      "description": "Stocke les configurations globales et les images du site.",
      "type": "object",
      "properties": {
        "schoolName": {
          "type": "string",
          "description": "Nom officiel de l'établissement."
        },
        "logoUrl": {
          "type": "string",
          "description": "URL du logo principal."
        },
        "images": {
          "type": "object",
          "description": "Dictionnaire des URLs d'images par emplacement.",
          "properties": {
            "hero_home": { "type": "string", "description": "Image de fond de l'accueil" },
            "campus_panoramic": { "type": "string", "description": "Bandeau panoramique des campus" },
            "campus_evron": { "type": "string", "description": "Photo Campus Evron" },
            "campus_bazeilles": { "type": "string", "description": "Photo Campus Sainte-Bazeilles" },
            "campus_tulle": { "type": "string", "description": "Photo Campus Sainte-Tulle" },
            "football_academy": { "type": "string", "description": "Photo section Football Academy" },
            "news_graduation": { "type": "string", "description": "Photo Actualité - Résultats Bac" },
            "news_science": { "type": "string", "description": "Photo Actualité - Labo Sciences" }
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["schoolName"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Document unique pour toute l'identité visuelle du site."
    }
  }
}
