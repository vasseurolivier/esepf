rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Paramètres globaux - Lecture publique, écriture autorisée pour le prototype
    // La sécurité est assurée par le mot de passe Yesacademy888$ dans l'interface admin
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    
    // Collections de contenu - Lecture publique pour les visiteurs
    match /informations/{infoId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Règle par défaut : accès refusé pour tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}