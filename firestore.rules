rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ACCÈS PUBLIC EN LECTURE
     * Autorise tout le monde à voir le contenu du site (indispensable pour l'affichage des photos et textes).
     */
    match /{document=**} {
      allow read: if true;
    }

    // --- Règles Spécifiques ---

    match /admins/{userId} {
      allow get: if request.auth != null;
      allow write: if false;
    }

    match /settings/{settingId} {
      allow write: if true; // Autorisé pour les modifications via l'espace admin
    }

    match /registrations/{registrationId} {
      allow create: if true;
      allow update, delete: if true;
    }
    
    match /figures/{figureId} { allow write: if true; }
    match /programs/{programId} { allow write: if true; }
    match /newsArticles/{articleId} { allow write: if true; }
    match /partners/{partnerId} { allow write: if true; }
  }
}