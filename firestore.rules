
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Paramètres globaux - lecture publique, écriture autorisée pour le prototype
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    
    // Collection pour les images
    match /images/{imageId} {
      allow read: if true; 
      allow write: if true; 
    }
    
    // Collection pour les informations publiques
    match /informations/{infoId} {
      allow read: if true; 
      allow write: if true; 
    }
    
    // Collection pour les articles/blog
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Collection pour les données de configuration
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Données sensibles
    match /private/{document=**} {
      allow read, write: if false; 
    }
    
    // Règle par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
