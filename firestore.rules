
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Paramètres globaux (AppSettings)
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    
    // Dossiers d'inscription
    match /registrations/{registrationId} {
      allow create: if true; // Tout le monde peut envoyer un dossier
      allow read, update, delete: if true; // Accès admin pour le prototype
    }
    
    // Collections de contenu
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /informations/{infoId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
