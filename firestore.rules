rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Vérification d'authentification pour la plupart des opérations
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Collection des paramètres globaux
    match /settings/{document} {
      // Lecture publique si nécessaire
      allow read: if true;
      // Écriture réservée aux admins
      allow write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Collection pour les images
    match /images/{imageId} {
      allow read: if true; // Lecture publique si ce sont des images à afficher
      allow write: if isAuthenticated(); // Écriture réservée aux utilisateurs connectés
    }
    
    // Collection pour les informations utilisateur
    match /users/{userId} {
      allow read: if true; // ou restreindre selon vos besoins
      allow write: if isOwner(userId); // Seul l'utilisateur peut modifier son profil
    }
    
    // Collection pour les données privées
    match /privateData/{document} {
      allow read, write: if isAuthenticated();
    }
    
    // Règle par défaut : refus explicite
    match /{document=**} {
      allow read, write: if false;
    }
  }
}