rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a Public-Read, Admin-Write model for a content-driven application. 
     *
     * DATA STRUCTURE
     * - Public Content: /figures, /programs, /newsArticles, /partners, /settings
     * - Admissions: /registrations (Public create, Admin read)
     * - System Data: /admins/{userId}
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    function matchesPathId(docId) {
      return request.resource.data.id == docId;
    }

    // --- Collection Rules ---

    match /admins/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /figures/{figureId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(figureId);
      allow update, delete: if isExistingAdmin();
    }

    match /programs/{programId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(programId);
      allow update, delete: if isExistingAdmin();
    }

    match /newsArticles/{articleId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(articleId);
      allow update, delete: if isExistingAdmin();
    }

    match /partners/{partnerId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(partnerId);
      allow update, delete: if isExistingAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || true; // Temporairement true pour l'accès via mot de passe admin sans auth Firebase
    }
  }
}