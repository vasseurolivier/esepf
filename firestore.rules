
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Paramètres globaux - Lecture et Écriture publiques
    // La protection est assurée par le mot de passe dans l'interface admin
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    
    // Collections de contenu - Lecture publique
    match /informations/{infoId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Règle par défaut
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
