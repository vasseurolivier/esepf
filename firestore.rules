rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permet à tout le monde de lire les réglages (pour afficher le logo sur le site)
    // Permet la modification des réglages (idéalement restreint à l'admin plus tard)
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    
    // Règle par défaut : accès refusé pour le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}