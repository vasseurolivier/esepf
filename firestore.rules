
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Accès total au document de configuration globale
    // La protection est faite via le mot de passe admin dans l'interface
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    
    // Autoriser les autres documents si nécessaire
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
