
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permet l'accès complet au document global pour la démo
    // Dans une version de production, on ajouterait 'if request.auth != null'
    match /settings/global {
      allow read, write: if true;
    }
    
    // Règle par défaut : accès refusé pour tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
